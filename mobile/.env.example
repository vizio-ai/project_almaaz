# =============================================================================
# .env.example — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayıp değerleri doldur:
#   cp .env.example .env
#
# .env dosyası .gitignore'a eklenmiştir. ASLA commit etme.
# Expo'da değişkenler EXPO_PUBLIC_ prefix'iyle public olur.
# =============================================================================

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase dashboard > Settings > API bölümünden al
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Geoapify (M4 — Place search, geocoding, autocomplete) ───────────────────
# myprojects.geoapify.com > Create Project > API Key
# Ücretsiz: 90,000 istek/ay
EXPO_PUBLIC_GEOAPIFY_KEY=...

# ─── Google Maps (react-native-maps — Android harita render) ──────────────────
# console.cloud.google.com > Maps SDK for Android/iOS (sadece Maps SDK, Places değil)
# Android build için app.json > plugins > react-native-maps > googleMapsApiKey'e de gir
EXPO_PUBLIC_GOOGLE_MAPS_KEY=...

# ─── App Config ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development        # development | staging | production
EXPO_PUBLIC_API_BASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co/functions/v1
